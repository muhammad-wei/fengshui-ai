# DeepSeek API (orchestration "leader")
DEEPSEEK_API_KEY=

# Alibaba Cloud Model Studio / DashScope (Wan2.7-Image + SenseVoice ASR)
DASHSCOPE_API_KEY=

# StepFun "Step Plan" cloud API (OpenAI-compatible) — formats DeepSeek's draft into strict JSON
STEP_API_KEY=
STEP_BASE_URL=https://api.stepfun.com/step_plan/v1
STEP_MODEL=step-3.7-flash

# Feature flags
SEND_IMAGE_TO_LLM=false
